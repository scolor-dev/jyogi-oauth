# PostgreSQL
POSTGRES_DB=jyogi_oauth
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Auth Server
AUTH_SERVER_PORT=8080
AUTH_DATABASE_URL=postgres://jyogi_auth:change-me@postgres:5432/jyogi_oauth?search_path=auth
AUTH_REDIS_URL=redis://redis:6379/0
AUTH_JWT_PRIVATE_KEY_PATH=/keys/private.pem
AUTH_JWT_PUBLIC_KEY_PATH=/keys/public.pem
# Optional multi-key rotation mode. When AUTH_JWT_KEYS_DIR is set, the
# auth-server loads *.public.pem from the directory, signs with
# ${AUTH_JWT_ACTIVE_KID}.private.pem, and publishes all public keys in JWKS.
# AUTH_JWT_KEYS_DIR=/keys/jwt
# AUTH_JWT_ACTIVE_KID=key-2026-06
AUTH_JWT_ISSUER=https://jyogi-auth.example.com
AUTH_JWT_KID=key-1
AUTH_SESSION_COOKIE_NAME=jyogi_sid
AUTH_SESSION_COOKIE_SECURE=true
AUTH_SESSION_COOKIE_DOMAIN=.example.com
AUTH_LOG_LEVEL=info

# Resource Server
RESOURCE_SERVER_HOST=0.0.0.0
RESOURCE_SERVER_PORT=8081
RESOURCE_DATABASE_URL=postgres://jyogi_resource:change-me@postgres:5432/jyogi_oauth?search_path=resource
RESOURCE_DATABASE_MAX_CONNECTIONS=10
RESOURCE_JWKS_URL=http://auth-server:8080/oauth/jwks
RESOURCE_JWKS_CACHE_TTL=3600
RESOURCE_JWT_ISSUER=https://jyogi-auth.example.com
RESOURCE_LOG_LEVEL=info
